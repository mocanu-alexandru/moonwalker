<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="6dp"
        android:textSize="13sp"
        android:text="○ oprit" />

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <Spinner android:id="@+id/modeSpinner"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" />
        <Spinner android:id="@+id/countySpinner"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <TextView android:id="@+id/speedLbl"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Viteză: 120 km/h" android:textSize="12sp" />
    <SeekBar android:id="@+id/speedBar"
        android:layout_width="match_parent" android:layout_height="wrap_content" />

    <TextView android:id="@+id/rowLbl"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="Distanță rânduri: 130 m" android:textSize="12sp" />
    <SeekBar android:id="@+id/rowBar"
        android:layout_width="match_parent" android:layout_height="wrap_content" />

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <Button android:id="@+id/btnStart"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:text="START" />
        <Button android:id="@+id/btnStop"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:text="STOP" />
        <Button android:id="@+id/btnClear"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:text="Șterge desen" />
    </LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <Button android:id="@+id/btnMock"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Developer Options"
            android:textSize="11sp" />
        <Button android:id="@+id/btnUpdate"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Verifică update"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
