<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <org.osmdroid.views.MapView
            android:id="@+id/map"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ImageButton
            android:id="@+id/btnHome"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="14dp"
            android:src="@android:drawable/ic_menu_mylocation"
            android:background="#DDFFFFFF"
            android:scaleType="centerInside"
            android:contentDescription="Acasă" />

    </FrameLayout>

    <!-- Banner permisiuni/setup — apare doar când lipsește ceva -->
    <TextView
        android:id="@+id/permsLbl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:textSize="11sp"
        android:visibility="gone" />

    <!-- Status live (faze, blocuri, acoperire, viteză învățată) -->
    <TextView
        android:id="@+id/status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:textSize="13sp"
        android:text="○ pornește automat la deschidere" />

    <!-- Buton unic de control (pornește/oprește) — eticheta se schimbă după stare.
         Pornirea e automată la deschiderea aplicației; ăsta e doar override manual. -->
    <Button android:id="@+id/btnStop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🤖 PORNEȘTE — acoperă România (autonom)"
        android:textSize="15sp"
        android:textStyle="bold"
        android:paddingTop="10dp"
        android:paddingBottom="10dp" />

    <!-- Setup: developer options (mock location) + update (mic) -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <Button android:id="@+id/btnMock"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Developer Options"
            android:textSize="11sp"
            style="?attr/borderlessButtonStyle" />
        <Button android:id="@+id/btnUpdate"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Verifică update"
            android:textSize="11sp"
            style="?attr/borderlessButtonStyle" />
    </LinearLayout>

    <TextView
        android:id="@+id/versionTv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="v1.0.0"
        android:textSize="10sp"
        android:textColor="#888888"
        android:gravity="center"
        android:paddingBottom="2dp" />

</LinearLayout>
